# --- Database (berlin-postgres docker container on the VPS) ---
DATABASE_URL=postgres://berlin:CHANGE_ME@127.0.0.1:5435/berlin

# --- Admin auth ---
ADMIN_USER=admin
# bcrypt hash of the admin password. Generate with:
#   node -e "console.log(require('bcryptjs').hashSync(process.argv[1],10))" 'your-strong-password'
ADMIN_PASSWORD_HASH=
# Random secret (32+ bytes) for signing the session cookie. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=

# --- Server (Astro node standalone, run by pm2 behind nginx) ---
HOST=127.0.0.1
PORT=3040

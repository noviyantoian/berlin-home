---
import Cta from "./Cta.astro";
import { WA_GENERAL } from "../data/site";
---
<section class="hero relative overflow-hidden" aria-labelledby="hero-title">
  <div class="wrap grid min-h-[100dvh] items-center gap-10 lg:grid-cols-12 lg:gap-12">
    <div class="hero-copy order-2 pb-14 lg:order-1 lg:col-span-7 lg:pb-0 lg:pr-4">
      <p class="kicker hero-stagger" style="--d:0ms">Spa &amp; Refleksi Panggilan · Jakarta &amp; Bali</p>
      <h1 id="hero-title" class="hero-stagger mt-5 text-display" style="--d:80ms">
        Pijat profesional,<br /><em>di tempat Anda.</em>
      </h1>
      <p class="lead hero-stagger mt-6 max-w-[46ch]" style="--d:160ms">
        Terapis bersertifikat datang ke rumah, hotel, atau apartemen Anda. Tersedia 24 jam di Jakarta &amp; Bali.
      </p>
      <div class="hero-stagger mt-9 flex flex-wrap items-center gap-3" style="--d:240ms">
        <Cta href={WA_GENERAL} label="Pesan via WhatsApp" location="hero" order lg />
        <a class="btn btn--ghost btn--lg" href="#layanan">Lihat layanan</a>
      </div>
    </div>

    <div class="hero-media order-1 lg:order-2 lg:col-span-5">
      <div class="relative">
        <span class="absolute -left-3 -top-3 hidden h-24 w-24 border-l-2 border-t-2 border-maroon lg:block" aria-hidden="true"></span>
        <img
          src="/assets/images/hero-portrait.webp"
          width="900" height="1200" fetchpriority="high"
          class="aspect-[3/4] w-full object-cover"
          alt="Terapis berseragam spa profesional memijat bahu klien yang tertutup handuk di kamar terang."
        />
      </div>
    </div>
  </div>
</section>

<style>
  .hero { padding-top: clamp(78px, 9vw, 110px); }
  @media (prefers-reduced-motion: no-preference) {
    .hero-stagger { opacity: 0; animation: hero-in .8s var(--ease) forwards; animation-delay: var(--d, 0ms); }
  }
  @keyframes hero-in { from { opacity: 0; transform: translateY(18px); } to { opacity: 1; transform: none; } }
</style>

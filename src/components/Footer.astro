---
import { Icon } from "astro-icon/components";
import { navLinks, WA_GENERAL, WA_DISPLAY, IG_URL } from "../data/site";
const year = new Date().getFullYear();
---
<footer id="kontak" class="border-t border-line bg-paper-2">
  <div class="wrap py-12 sm:py-16 lg:py-20">
    <div class="grid gap-10 md:grid-cols-[1.5fr_1fr_1fr]">
      <div>
        <a class="font-display text-[2rem] font-medium tracking-tight text-ink" href="#top">Berlin<span class="text-maroon">.</span> Home Spa</a>
        <p class="mt-4 max-w-[34ch] text-muted">Layanan spa &amp; refleksi panggilan oleh terapis bersertifikat untuk Jakarta &amp; Bali. Higienis, nyaman, tepat waktu.</p>
      </div>

      <nav aria-label="Tautan cepat">
        <h3 class="text-sm font-semibold uppercase tracking-[0.12em] text-faint">Jelajahi</h3>
        <ul class="mt-4 space-y-2.5">
          {navLinks.map((l) => (
            <li><a class="text-ink-soft transition-colors hover:text-maroon" href={l.href}>{l.label}</a></li>
          ))}
        </ul>
      </nav>

      <div>
        <h3 class="text-sm font-semibold uppercase tracking-[0.12em] text-faint">Kontak</h3>
        <ul class="mt-4 space-y-2.5">
          <li><a class="inline-flex items-center gap-2 text-ink-soft transition-colors hover:text-maroon" data-cta="footer" data-order href={WA_GENERAL} target="_blank" rel="noopener"><Icon name="ph:whatsapp-logo-fill" /> {WA_DISPLAY}</a></li>
          <li><a class="inline-flex items-center gap-2 text-ink-soft transition-colors hover:text-maroon" href={IG_URL} target="_blank" rel="noopener"><Icon name="ph:instagram-logo" /> Instagram</a></li>
          <li><span class="inline-flex items-center gap-2 text-ink-soft"><Icon name="ph:clock" /> Buka 24 jam, setiap hari</span></li>
        </ul>
      </div>
    </div>

    <div class="mt-14 flex flex-wrap items-center justify-between gap-3 border-t border-line pt-6 text-sm text-faint">
      <span>© {year} Berlin Home Spa. Hanya layanan panggilan, tanpa lokasi fisik.</span>
      <a class="transition-colors hover:text-maroon" href="/privacy">Kebijakan Privasi</a>
    </div>
  </div>
</footer>

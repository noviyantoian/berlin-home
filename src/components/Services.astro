---
import { Icon } from "astro-icon/components";
import { services } from "../data/site";
---
<section id="layanan" class="sect" aria-labelledby="layanan-title">
  <div class="wrap">
    <div class="max-w-[40ch]">
      <p class="kicker">Layanan</p>
      <h2 id="layanan-title" class="mt-4 text-h2">Empat perawatan, satu tujuan: <em>tubuh yang pulih.</em></h2>
    </div>

    <div class="mt-10 grid gap-5 sm:mt-14 sm:grid-cols-2 lg:gap-6">
      {services.map((s) => (
        <article class="reveal reveal-up group flex flex-col border border-line bg-paper transition-colors hover:border-maroon/40">
          <div class="overflow-hidden">
            <img src={s.img} width="800" height="1000" loading="lazy" alt={s.alt}
              class="aspect-[4/5] w-full object-cover transition-transform duration-700 group-hover:scale-[1.03]" />
          </div>
          <div class="flex flex-1 flex-col p-6 sm:p-7">
            <div class="flex items-baseline gap-3">
              <span class="font-display text-2xl leading-none text-maroon">{s.no}</span>
              <h3 class="text-h3">{s.title}</h3>
            </div>
            <p class="mt-3 flex-1 text-[0.95rem] text-muted">{s.desc}</p>
            <div class="mt-5 flex flex-wrap items-center gap-2">
              <span class="tag">{s.duration}</span>
              {s.benefits.map((b) => <span class="tag">{b}</span>)}
            </div>
            <a class="ulink mt-5 inline-flex items-center gap-1.5 text-[0.95rem]" href={s.wa} data-cta={`service-${s.id}`} data-order data-service={s.title} target="_blank" rel="noopener">
              Tanya &amp; pesan <Icon name="ph:arrow-up-right" />
            </a>
          </div>
        </article>
      ))}
    </div>

    <p class="mt-8 flex items-center gap-2 text-sm text-faint sm:mt-10">
      <Icon name="ph:info" /> Harga &amp; durasi detail dikonfirmasikan langsung via WhatsApp sesuai kebutuhan Anda.
    </p>
  </div>
</section>

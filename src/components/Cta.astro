---
import { Icon } from "astro-icon/components";
interface Props {
  href: string;
  label: string;
  location: string;          // data-cta tracking label
  variant?: "primary" | "ghost" | "on-maroon";
  lg?: boolean;
  order?: boolean;           // opens lead-form modal (href is the no-JS fallback)
  class?: string;
}
const { href, label, location, variant = "primary", lg = false, order = false, class: cls = "" } = Astro.props;
const klass = ["btn", `btn--${variant}`, lg && "btn--lg", cls].filter(Boolean).join(" ");
---
<a class={klass} href={href} data-cta={location} data-order={order ? "" : undefined} target="_blank" rel="noopener">
  <Icon name="ph:whatsapp-logo-fill" />{label}
</a>

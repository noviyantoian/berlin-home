---
import Base from "../../layouts/Base.astro";
export const prerender = false;

const hasError = Astro.url.searchParams.has("error");
---
<Base title="Masuk — Admin Berlin Home Spa" description="Dashboard admin">
  <meta slot="head" name="robots" content="noindex,nofollow" />
  <main class="wrap mx-auto flex min-h-[100dvh] max-w-[25rem] flex-col justify-center py-16">
    <a class="font-display text-[1.5rem] font-medium tracking-tight text-ink" href="/">Berlin<span class="text-maroon">.</span> Home Spa</a>
    <h1 class="mt-8 font-display text-[2rem] leading-tight">Masuk dashboard</h1>
    <p class="mt-2 text-sm text-muted">Khusus admin Berlin Home Spa.</p>

    {hasError && (
      <p class="mt-5 border border-maroon/30 bg-blush px-4 py-3 text-sm text-maroon-ink">Username atau password salah.</p>
    )}

    <form method="POST" action="/api/admin/login" class="mt-6 grid gap-4">
      <div class="grid gap-1.5">
        <label class="text-sm font-medium" for="user">Username</label>
        <input class="fld" id="user" name="user" type="text" autocomplete="username" required autofocus />
      </div>
      <div class="grid gap-1.5">
        <label class="text-sm font-medium" for="password">Password</label>
        <input class="fld" id="password" name="password" type="password" autocomplete="current-password" required />
      </div>
      <button class="btn btn--primary btn--lg mt-1 w-full" type="submit">Masuk</button>
    </form>
  </main>
</Base>

<style>
  .fld {
    width: 100%; padding: 0.8rem 1rem; font: inherit; font-size: 1rem; color: var(--color-ink);
    background: #fff; border: 1.5px solid var(--color-line); border-radius: 12px; transition: border-color .2s, box-shadow .2s;
  }
  .fld:focus { outline: none; border-color: var(--color-maroon); box-shadow: 0 0 0 3px rgba(190, 49, 68, 0.15); }
</style>
